# Copy this file to .env and fill in the values. .env is NEVER committed.

# Public host of the tool
PUBLIC_HOST=analytics.example.com

# ClickHouse (strong password: openssl rand -hex 24)
CLICKHOUSE_PASSWORD=change_me

# Dashboard auth (login + 2FA)
AUTH_SECRET=change_me_openssl_rand_hex_32
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_strong_password

# Read-only API token for the CLI (openssl rand -hex 32). Optional: leave empty
# to disable the CLI. It can only read stats and list sites, never write.
INSIGHT_API_TOKEN=

# Mapbox public token (URL-restricted to your domain) for the live map.
MAPBOX_TOKEN=

# Geolocation needs no key. Country comes from Cloudflare's CF-IPCountry header
# when the domain is proxied (orange cloud). City and region come from GA4 when
# connected, or from Cloudflare's visitor location headers if you enable them.
