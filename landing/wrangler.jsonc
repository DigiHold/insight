{
  // Cloudflare Worker for the public landing page. Deployed from Git (Workers Builds).
  // The dashboard Worker name MUST match "name" below, or the build fails.
  "name": "insight-landing",
  "main": "worker.js",
  "compatibility_date": "2026-06-01"
  // The custom domain (insightsite.nicolaslecocq.com) is attached from the
  // dashboard (Worker > Settings > Domains & Routes > Add > Custom Domain),
  // because the Git build token is not scoped to edit this zone's DNS/routes.
}
